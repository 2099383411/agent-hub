# Agent Hub 环境变量配置
# 复制此文件为 .env 并修改实际值

# JWT 签名密钥（生产环境请用 openssl rand -hex 32 生成）
HUB_SECRET_KEY=change-me-in-production

# 管理员初始密码（首次登录后可修改）
HUB_ADMIN_PASSWORD=admin123

# 数据库连接（默认 SQLite）
HUB_DATABASE_URL=sqlite+aiosqlite:///app/data/agent_hub.db

# 中台对外可访问地址（Agent 用来连接中台的地址）
# 例如：http://192.168.1.100:8200
# 留空则自动检测本机 IP
HUB_PUBLIC_URL=

# 调试模式
HUB_DEBUG=false
